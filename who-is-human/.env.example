# ─────────────────────────────────────────────────────────────
# Who is Human — configuration
# Copy this file to `.env` and fill in what you need.
# The game is fully playable with the zero-config "demo" backend,
# so you can leave everything blank to start.
# ─────────────────────────────────────────────────────────────

# Which backend drives the 6 AI agents:
#   demo  = scripted/heuristic agents, no API key, instant (default)
#   api   = Anthropic API (needs ANTHROPIC_API_KEY below)
#   file  = inbox/outbox bridge — each agent driven by a separate
#           Claude Code / Codex session (see docs/setup-claude-code-agents.md)
WIH_AGENT_BACKEND=demo

# Server port (5173 is Vite's default — 8787 avoids clashing with a Vite dev server)
PORT=8787

# ── Anthropic API backend (WIH_AGENT_BACKEND=api) ───────────────
# Get a key at https://console.anthropic.com/  (only sent to api.anthropic.com)
ANTHROPIC_API_KEY=
# Model for AI agents. Opus is strongest; downgrade to save cost while testing.
#   claude-opus-4-8 | claude-sonnet-5 | claude-haiku-4-5
WIH_MODEL=claude-opus-4-8

# ── File-bridge backend (WIH_AGENT_BACKEND=file) ────────────────
# Folder where the game drops per-agent inbox/outbox turn files.
WIH_AGENT_WORKSPACE=./agent-workspace
# How long (ms) the game waits for a coding-agent session to answer a turn
# before falling back to a safe default action.
WIH_FILE_TIMEOUT_MS=180000
